# Trading Cockpit Bot — Environment Variables
# Copy this file to .env and fill in your keys.

# ── Required ─────────────────────────────────────────────────────────────────
# Get from https://t.me/BotFather (free)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── AI Layer (OpenRouter) — get $1 free credit ────────────────────────────────
# Sign up: https://openrouter.ai/credits
# Models: openai/gpt-4o, anthropic/claude-3.5-sonnet, google/gemini-2.0-flash
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-4o

# ── Optional: News (free tier available) ─────────────────────────────────────
# NewsAPI: https://newsapi.org/register
NEWS_API_KEY=

# ── Optional: Real-time stock data (free tier) ───────────────────────────────
# Polygon.io: https://polygon.io/getting-started
POLYGON_API_KEY=

# ── Optional: Exchange APIs (for real trading) ────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── App settings ──────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
